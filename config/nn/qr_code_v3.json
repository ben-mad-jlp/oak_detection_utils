          "mean": [0, 0, 0],
          "scale": [255, 255, 255],
          "reverse_channels": true
        }
      }
    ],
    "outputs": [
      {
        "name": "output",
        "dtype": "float16"
      }
    ],
    "heads": [
      {
        "parser": "YOLO",
        "metadata": {
          "subtype": "yolov8",
          "n_classes": 1,
          "classes": ["center"],
          "iou_threshold": 0.5,
          "conf_threshold": 0.3
        }
      }
    ]
  }
