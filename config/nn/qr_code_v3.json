{
  "config_version": "1.0",
  "model": {
    "metadata": {
      "name": "qr_code_yolov8n",
      "path": "/home/jlp/claude_share/qr_code_model_openvino_2022.1_6shave.blob"
    },
    "inputs": [
      {
        "name": "input",
        "dtype": "float16",
